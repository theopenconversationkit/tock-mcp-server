# Exemple de variables d'environnement pour le développement local
# Copier en .env et charger avec: export $(cat .env | xargs)

# URLs et identifiants Tock
TOCK_MCP_TOCK_BASE_URL=http://localhost:8080
TOCK_MCP_TOCK_NAMESPACE=dev
TOCK_MCP_TOCK_BOT=testbot
TOCK_MCP_TOCK_CONNECTOR=web_connector
TOCK_MCP_TOCK_USER_ID=mcp-local-user

# En-têtes HTTP personnalisés
# Format: TOCK_MCP_TOCK_EXTRA_HEADERS_<NAME>=value
TOCK_MCP_TOCK_EXTRA_HEADERS_X_TOKI_FILTER=category:faq
TOCK_MCP_TOCK_EXTRA_HEADERS_X_CUSTOM_HEADER=dev-value

# Configuration serveur
TOCK_MCP_SERVER_ADDR=:8083
TOCK_MCP_SERVER_TOOL_NAME=ask_tock
TOCK_MCP_SERVER_TOOL_DESCRIPTION="Ask a question to the Tock documentary chatbot (RAG)"

